# Fidelio environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local.

# Anthropic API key — get one from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model ID — leave as-is unless you have reason to change
ANTHROPIC_MODEL=claude-sonnet-4-6

# financial-hub-mcp environment (passed through to the MCP subprocess)
# This identifies your requests to SEC EDGAR — SEC bans generic User-Agent headers.
SEC_USER_AGENT_EMAIL=

# FRED API key for economic data (free, https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Finnhub API key for live stock quotes (free, https://finnhub.io/register)
FINNHUB_API_KEY=

# Log level — "info" in production, "debug" when troubleshooting
LOG_LEVEL=info
