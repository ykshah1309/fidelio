# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do not commit!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime artifacts
/tmp-uploads/
/tmp-reports/

# sample PDFs that may contain PII — block any *.pdf, but whitelist the
# synthetic samples produced by `npm run samples` (fictional data, safe).
public/samples/*.pdf
!public/samples/.gitkeep
!public/samples/sample-401k.pdf
!public/samples/sample-paystub.pdf
